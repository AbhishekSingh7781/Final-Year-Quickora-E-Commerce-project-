# Quickora Deployment Environment Variables
# Copy this file to .env and fill in the production values

# Secret for JWT signing (use a long random string in production)
JWT_SECRET=your_jwt_secret_here

# MongoDB Connection String (Atlas URI for production)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/quickora?retryWrites=true&w=majority

# Execution Mode: production or development
NODE_ENV=production

# Server Port (most platforms like Heroku/Render set this automatically)
PORT=5001

# Frontend URL (for CORS setup)
FRONTEND_URL=https://your-frontend-domain.vercel.app
